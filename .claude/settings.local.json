{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python context_hook.py --timing session-start",
            "timeout": 15000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python context_hook.py --timing every-message",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
